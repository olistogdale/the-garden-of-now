{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.int.test.ts",
    "src/**/tests",
    "src/**/test-utils.ts"
  ]
}
